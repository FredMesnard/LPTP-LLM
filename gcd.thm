:- assert_pred([d(divisor,2),$(x),$(y)],@(ex,[z],[&,[succeeds,[n(nat,1),$(z)]],[=,[f(@*,2),$(x),$(z)],$(y)]])).
:- assert_fact(lemma,(div):plus,@(all,[x,y,z,d],[=>,[&,[succeeds,[n(nat,1),$(y)]],[succeeds,[n(nat,1),$(d)]],[succeeds,[n(plus,3),$(x),$(y),$(z)]],[d(divisor,2),$(d),$(x)],[d(divisor,2),$(d),$(y)]],[d(divisor,2),$(d),$(z)]])).
:- assert_fact(lemma,(div):minus,@(all,[x,y,z,d],[=>,[&,[succeeds,[n(nat,1),$(z)]],[succeeds,[n(nat,1),$(d)]],[succeeds,[n(plus,3),$(x),$(y),$(z)]],[d(divisor,2),$(d),$(x)],[d(divisor,2),$(d),$(z)]],[d(divisor,2),$(d),$(y)]])).
:- assert_fact(lemma,gcd:types,[&,@(all,[x,y,d],[=>,[succeeds,[n(gcd,3),$(x),$(y),$(d)]],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]]],[succeeds,[n(nat,1),$(d)]]]]),@(all,[x,y,d],[=>,[succeeds,[n(gcd_leq,3),$(x),$(y),$(d)]],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]]],[succeeds,[n(nat,1),$(d)]]]])]).
:- assert_fact(corollary,gcd:types,@(all,[x,y,d],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]],[succeeds,[n(gcd,3),$(x),$(y),$(d)]]],[succeeds,[n(nat,1),$(d)]]])).
:- assert_fact(corollary,gcd_leq:types,@(all,[x,y,d],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]],[succeeds,[n(gcd_leq,3),$(x),$(y),$(d)]]],[succeeds,[n(nat,1),$(d)]]])).
:- assert_fact(lemma,gcd:(div),[&,@(all,[x,y,d],[=>,[succeeds,[n(gcd,3),$(x),$(y),$(d)]],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]]],[&,[d(divisor,2),$(d),$(x)],[d(divisor,2),$(d),$(y)]]]]),@(all,[x,y,d],[=>,[succeeds,[n(gcd_leq,3),$(x),$(y),$(d)]],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]]],[&,[d(divisor,2),$(d),$(x)],[d(divisor,2),$(d),$(y)]]]])]).
:- assert_fact(theorem,gcd:(div),@(all,[x,y,d],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]],[succeeds,[n(gcd,3),$(x),$(y),$(d)]]],[&,[d(divisor,2),$(d),$(x)],[d(divisor,2),$(d),$(y)]]])).
:- assert_fact(lemma,gcd:complete,[&,@(all,[x,y,d],[=>,[succeeds,[n(gcd,3),$(x),$(y),$(d)]],@(all,[e],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]],[succeeds,[n(nat,1),$(e)]],[d(divisor,2),$(e),$(x)],[d(divisor,2),$(e),$(y)]],[d(divisor,2),$(e),$(d)]])]),@(all,[x,y,d],[=>,[succeeds,[n(gcd_leq,3),$(x),$(y),$(d)]],@(all,[e],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]],[succeeds,[n(nat,1),$(e)]],[d(divisor,2),$(e),$(x)],[d(divisor,2),$(e),$(y)]],[d(divisor,2),$(e),$(d)]])])]).
:- assert_fact(theorem,gcd:complete,@(all,[x,y,d,e],[=>,[&,[succeeds,[n(gcd,3),$(x),$(y),$(d)]],[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]],[succeeds,[n(nat,1),$(e)]],[d(divisor,2),$(e),$(x)],[d(divisor,2),$(e),$(y)]],[d(divisor,2),$(e),$(d)]])).
:- assert_fact(lemma,gcd:termination,@(all,[n],[=>,[succeeds,[n(nat,1),$(n)]],[&,@(all,[x,y,d],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]],[succeeds,[n(@<,2),[f(@+,2),$(x),$(y)],$(n)]],[succeeds,[n(@=<,2),$(x),$(y)]]],[terminates,[n(gcd_leq,3),$(x),$(y),$(d)]]]),@(all,[x,y,d],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]],[succeeds,[n(@<,2),[f(@+,2),$(x),$(y)],$(n)]]],[terminates,[n(gcd,3),$(x),$(y),$(d)]]])]])).
:- assert_fact(theorem,gcd:termination,@(all,[x,y,d],[=>,[&,[succeeds,[n(nat,1),$(x)]],[succeeds,[n(nat,1),$(y)]]],[terminates,[n(gcd,3),$(x),$(y),$(d)]]])).
