:- initialize.

:- needs_gr(nat).
:- needs_thm(nat).


:- needs_gr(gcd).
:- needs_thm(gcd).

:- compile_gr(sqrt2).
:- needs_gr(sqrt2).
:- tex_file(sqrt2_v3_epilog).

/* %%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

We introduce a new Prolog clause:

sqrt_two_is_rational :- 
	nat(S),
	plus(P,Q,S),
	gcd(P,Q,s(0)),
	times(P,P,P2),
	times(Q,Q,Q2),
	plus(Q2,Q2,P2).

and show that it cannot succed: ~ (succeeds sqrt_two_is_rational).

NB:  as we know sqrt_two_is_rational is non-terminating
and as 'fails' in LPTP means finite failure, we do not have the dichotomy
(succeeds sqrt_two_is_rational) exclusive-or (fails sqrt_two_is_rational).
The best we can do is showing  ~ (succeeds sqrt_two_is_rational),
proved by Claude under guidance at is the end of the file.

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%% */

:- definition_pred(coprime,2,
all [p,q]: coprime(?p,?q) 
<=> (all r: succeeds nat(?r) & divisor(?r,?p) & divisor(?r,?q) => ?r = s(0))).

:- lemma(square:existence,
all n: succeeds nat(?n) => (ex p: succeeds times(?n,?n,?p)),
assume(succeeds nat(?n),
 [succeeds nat(?n) & succeeds nat(?n),
  ex z: succeeds times(?n,?n,?z) by lemma(times:existence)],
 ex p: succeeds times(?n,?n,?p))
).

:- lemma(square:uniqueness,
all [n,sn,sp]: succeeds times(?n,?n,?sn) & succeeds times(?n,?n,?sp) => ?sn = ?sp,
assume(succeeds times(?n,?n,?sn) & succeeds times(?n,?n,?sp),
 [?sn = ?sp by lemma(times:uniqueness)],
 ?sn = ?sp)
).

:- definition_fun(square,1,
all [n,p]: succeeds nat(?n) => (square(?n) = ?p <=> succeeds times(?n,?n,?p)),
existence by lemma(square:existence),
uniqueness by lemma(square:uniqueness)).

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

% LLM-generated
:- lemma(nat:natsquare,
all n: succeeds nat(?n) => succeeds nat(square(?n)),
assume(succeeds nat(?n),
 [succeeds times(?n,?n,square(?n)) by existence(square,1),
  succeeds times(?n,?n,square(?n)) & succeeds nat(?n) => 
    succeeds nat(square(?n)) by lemma(times:types:2),
  succeeds nat(square(?n))],
 succeeds nat(square(?n)))
).

% LLM-generated
:- lemma(sqr2:4, 
square(s(s(0))) = s(s(s(s(0)))),
[succeeds nat(0),
 succeeds nat(s(0)),
 succeeds nat(s(s(0))),
 % times(s(s(0)), s(s(0)), 4) se décompose en :
 % times(s(0), s(s(0)), a) et plus(s(s(0)), a, 4)
 % times(s(0), s(s(0)), 2) se décompose en :
 % times(0, s(s(0)), 0) et plus(s(s(0)), 0, 2)
 succeeds times(0,s(s(0)),0),
 succeeds plus(s(s(0)),0,s(s(0))),
 succeeds times(s(0),s(s(0)),s(s(0))),
 % plus(s(s(0)), s(s(0)), s(s(s(s(0)))))
 succeeds plus(s(0),s(s(0)),s(s(s(0)))),
 succeeds plus(s(s(0)),s(s(0)),s(s(s(s(0))))),
 succeeds times(s(s(0)),s(s(0)),s(s(s(s(0))))),
 square(s(s(0))) = s(s(s(s(0)))) by uniqueness(square,1)]
).


% LLM-generated
:- lemma(twotimes:even,
all [n,p]: succeeds nat(?p) & s(s(0)) @* ?p = ?n => succeeds even(?n),
induction(
 [all p: succeeds nat(?p) => (all n: s(s(0)) @* ?p = ?n => succeeds even(?n))],
 [step([],
   [],
   assume(s(s(0)) @* 0 = ?n,
    [succeeds nat(s(s(0))),
     s(s(0)) @* 0 = 0 by lemma(times:zero),
     ?n = 0,
     succeeds even(0)],
    succeeds even(?n)),
   all n: s(s(0)) @* 0 = ?n => succeeds even(?n)),
  step([p],
   [all n: s(s(0)) @* ?p = ?n => succeeds even(?n),
    succeeds nat(?p)],
   assume(s(s(0)) @* s(?p) = ?n,
    [succeeds nat(s(0)),
     succeeds nat(s(s(0))),
     succeeds nat(s(?p)),
     s(s(0)) @* s(?p) = s(?p) @+ s(0) @* s(?p) by corollary(times:successor),
     s(0) @* s(?p) = s(?p) by lemma(times:one),
     s(s(0)) @* s(?p) = s(?p) @+ s(?p),
     s(?p) @+ s(?p) = s(?p @+ s(?p)) by corollary(plus:successor),
     ?p @+ s(?p) = s(?p) @+ ?p by theorem(plus:commutative),
     s(?p) @+ ?p = s(?p @+ ?p) by corollary(plus:successor),
     ?p @+ s(?p) = s(?p @+ ?p),
     s(?p) @+ s(?p) = s(s(?p @+ ?p)),
     succeeds nat(?p @+ ?p) by corollary(plus:types),
     s(s(0)) @* ?p = ?p @+ s(0) @* ?p by corollary(times:successor),
     s(0) @* ?p = ?p by lemma(times:one),
     s(s(0)) @* ?p = ?p @+ ?p,
     s(s(0)) @* ?p = ?p @+ ?p => succeeds even(?p @+ ?p),
     succeeds even(?p @+ ?p),
     s(s(0)) @* s(?p) = s(s(?p @+ ?p)),
     ?n = s(s(?p @+ ?p)),
     succeeds even(s(s(?p @+ ?p))),
     succeeds even(?n)],
    succeeds even(?n)),
   all n: s(s(0)) @* s(?p) = ?n => succeeds even(?n))])
).

