:- lemma(even:twotimes,
all n: succeeds even(?n) => (ex p: succeeds nat(?p) & ?n = s(s(0)) @* ?p),
induction(
 [all n: succeeds even(?n) => (ex p: succeeds nat(?p) & ?n = s(s(0)) @* ?p)],
 [step([],
   [],
   [succeeds nat(s(s(0))),
    s(s(0)) @* 0 = 0 by lemma(times:zero),
    succeeds nat(0) & 0 = s(s(0)) @* 0,
