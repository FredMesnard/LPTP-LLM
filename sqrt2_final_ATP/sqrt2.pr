:- lemma(even:succ:odd,
all p: succeeds even(?p) => succeeds odd(s(?p)),
induction(
 [all p: succeeds even(?p) => succeeds odd(s(?p))],
 [step([],
   [],
   succeeds odd(s(0)),
   succeeds odd(s(0))),
  step([p],
   [succeeds odd(s(?p)),
    succeeds even(?p)],
   succeeds odd(s(s(s(?p)))),
   succeeds odd(s(s(s(?p)))))])
).

:- lemma(odd:succ:even,
