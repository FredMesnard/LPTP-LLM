:- lemma(gcd:complete,
(all [x,y,d]: succeeds gcd(?x,?y,?d) =>
   (all e: succeeds nat(?x) & succeeds nat(?y) & succeeds nat(?e) &
     divisor(?e,?x) & divisor(?e,?y) => divisor(?e,?d))) &
(all [x,y,d]: succeeds gcd_leq(?x,?y,?d) =>
   (all e: succeeds nat(?x) & succeeds nat(?y) & succeeds nat(?e) &
